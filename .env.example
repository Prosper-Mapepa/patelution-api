# Database (required). On Railway: add Postgres plugin and use DATABASE_URL from variables.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# JWT signing secret (required for auth). Use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-secret-change-me"

# Port (optional). Railway sets PORT automatically; default 4000 for local.
# PORT=4000

# Allowed CORS origins, comma-separated (optional). Default: http://localhost:3000
# Example for production: https://your-app.vercel.app,https://www.yourdomain.com
# CORS_ORIGIN="https://your-frontend.vercel.app"
